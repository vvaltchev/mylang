# map() then filter() over a large array, each calling a lambda per element
var scale = 1;
if (len(argv) > 0)
    scale = int(argv[0]);

var SZ = 500000 * scale;
var a = range(SZ);   # [0..SZ-1] - matches Python's list(range(SZ))

var b = map(func(x) => x * 2, a);
var c = filter(func(x) => x % 3 == 0, b);

print("result:", len(c));
