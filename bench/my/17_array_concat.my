# array concatenation with `+` (builds a fresh array each time)
var scale = 1;
if (len(argv) > 0)
    scale = int(argv[0]);

var a = range(500);   # [0..499] - matches Python's list(range(500))
var b = range(500);

var N = 100000 * scale;
var total = 0;

for (var i = 0; i < N; i += 1) {
    var c = a + b;
    total += len(c);
    total = total % 1000000007;
}

print("result:", total);
