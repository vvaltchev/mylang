# foreach with the `indexed` keyword (equivalent of Python's enumerate)
var scale = 1;
if (len(argv) > 0)
    scale = int(argv[0]);

var a = range(1000000);   # [0..999999] - matches Python's list(range(...))

var R = 3 * scale;
var s = 0;

for (var k = 0; k < R; k++) {
    foreach (var i, e in indexed a)
        s += i * e;
    s = s % 1000000007;
}

print("result:", s);
