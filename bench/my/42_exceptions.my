# throw/catch user exceptions in a loop (exceptions as control flow)
struct Even { int i; }
struct Odd { int i; }

var scale = 1;
if (len(argv) > 0)
    scale = int(argv[0]);

var N = 200000 * scale;
var caught = 0;

for (var i = 0; i < N; i++) {
    try {
        if (i % 2 == 0) {
            throw Even(i);
        } else {
            throw Odd(i);
        }
    } catch (Even) {
        caught++;
    } catch (Odd) {
        caught += 2;
    }
}

print("result:", caught);
