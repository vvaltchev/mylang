# A floating-point reduction (a numeric series): dense double arithmetic that
# static type inference turns into unboxed float ops - a case that particularly
# benefits from the type system.
var scale = 1;
if (len(argv) > 0)
    scale = int(argv[0]);

var N = 2000000 * scale;
var total = 0.0;

for (var i = 1; i < N; i++) {
    var x = i * 1.0;
    total += x / (x + 1.0) - 0.5 / x + 1.0 / (x * x);
}

print("result:", total);
